# Findora — root environment file, read by `docker compose` (docker/docker-compose.yml)
# Copy this to `.env` in the project root: cp .env.example .env
# Then edit the values below. Every key here has a safe default in
# docker-compose.yml, so the stack still runs with this file untouched —
# but AI explanations and emails will just be logged instead of sent/real.

# --- Auth secrets — CHANGE THESE before deploying anywhere public ---
JWT_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

# --- URLs ---
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Groq (AI match explanations) ---
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Brevo (transactional email: verification, reset, match alerts) ---
# Free API key: https://app.brevo.com -> Settings -> SMTP & API -> API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@findora.app
BREVO_SENDER_NAME=Findora

# --- Google Maps (live maps + location picker) ---
# Key: https://console.cloud.google.com/google/maps-apis
# Enable "Maps JavaScript API" for this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Optional: Cloudinary photo storage (default: local disk /uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
